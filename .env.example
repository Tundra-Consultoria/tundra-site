# Variáveis de ambiente do formulário de contato.
# Na Vercel: Settings → Environment Variables (NÃO faça commit do .env real).
# Localmente: copie para ".env" e rode `vercel dev`.

# Chave da API do Resend — crie em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# E-mail que vai RECEBER as mensagens do formulário
CONTACT_TO=contato@tundraconsultoria.com.br

# (Opcional) Remetente. Em produção use um e-mail de um domínio verificado
# no Resend. Sem isso, usa o remetente de teste do Resend.
# CONTACT_FROM=Tundra Site <site@tundraconsultoria.com.br>
